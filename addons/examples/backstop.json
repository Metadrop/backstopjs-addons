{
  "id": "backstop",
  "viewports": [
    {
      "label": "phone",
      "width": 375,
      "height": 667
    },
    {
      "label": "tablet",
      "width": 1024,
      "height": 768
    },
    {
      "label": "desktop",
      "width": 1600,
      "height": 900
    }
  ],
  "onBeforeScript": "onBefore.js",
  "onReadyScript": "onReady.js",
  "cookiePath": "cookies.json",
  "scenarios": [
  {
      "label": "Homepage",
      "url": "https://web/",
      "readySelector": "body"
    }
  ],
  "paths": {
    "bitmaps_reference": "bitmaps_reference",
    "bitmaps_test": "bitmaps_test",
    "engine_scripts": "engine_scripts",
    "html_report": "html_report",
    "ci_report": "ci_report"
  },
  "report": [
    "browser"
  ],
  "engine": "puppeteer",
  "engineOptions": {
    "args": [
      "--ignore-certificate-errors",
      "--no-sandbox",
      "--disable-setuid-sandbox",
      "--font-render-hinting=none"
    ],
    "gotoParameters": {
      "waitUntil": [
        "networkidle0"
      ]
    }
  },
  "debug": false,
  "debugWindow": false,
  "backstopjsAddons": {
    "path": "/src/tests/common/libraries/backstopjs-addons"
  }
}
